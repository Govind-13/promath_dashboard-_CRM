# MongoDB
MONGO_DB=promath_crm
MONGODB_URI=mongodb+srv://<db_username>:<db_password>@<cluster-host>/?appName=CRM
MONGO_STORAGE_COLLECTION=app_storage
MONGO_AUDIT_COLLECTION=audit_log
MONGO_USERS_COLLECTION=users

# Authentication
JWT_SECRET=<long-random-secret>
JWT_EXPIRES_IN=8h
CORS_ORIGINS=http://127.0.0.1:5173

# Default admin seed
ADMIN_EMAIL=<admin-email>
ADMIN_PASSWORD=<admin-password>
ADMIN_NAME=Promath Admin

# Password reset email (SMTP)
APP_URL=http://127.0.0.1:5173
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=<smtp-username>
SMTP_PASS=<smtp-password>
SMTP_FROM=Promath CRM <no-reply@example.com>

# Python frontend runtime
HOST=0.0.0.0
NEST_API_URL=http://127.0.0.1:4000
APP_ENV=development
